{
  "id": "EPHRAEM-PC_Listener",
  "name": "Premiere Companion (Listener)",
  "shortname": "PCListener",
  "version": "1.0.1",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.1"
  },
  "manifestVersion": 5,
  "requiredPermissions": {
    "localFileSystem": "request",
    "clipboard": "readAndWrite",
    "network": {
      "domains": "all"
    }
  },
  "entrypoints": [
    {
      "id": "starterpanel",
      "type": "panel",
      "minimumSize": {
        "width": 430,
        "height": 500
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 230,
        "height": 300
      },
      "preferredFloatingSize": {
        "width": 400,
        "height": 300
      },
      "label": {
        "default": "Premiere Companion (Listener)"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/dark@1x.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "darkest",
            "dark",
            "medium"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/light@1x.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/plugin@1x.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium",
        "lightest",
        "light",
        "all"
      ],
      "species": [
        "pluginList"
      ]
    }
  ]
}